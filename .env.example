# Database
DATABASE_URL=postgresql+asyncpg://cps:cps_dev_password@localhost:5432/cps
TEST_DATABASE_URL=postgresql+asyncpg://cps_test:cps_test_password@localhost:5433/cps_test

# CCC chart download
CCC_BASE_URL=https://charts.camelcamelcamel.com/us
CCC_RATE_LIMIT=1.0
CCC_RETRY_MAX=3
CCC_BACKOFF_BASE=2.0
CCC_COOLDOWN_SECS=60

# Alerts (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL_TO=your-email@example.com
ALERT_EMAIL_FROM=alerts@yourdomain.com

# Storage
DATA_DIR=data

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
